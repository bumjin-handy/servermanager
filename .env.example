# Per-server credentials example
# Each registered server points to its own .env file path.
# Example layout:
#   %APPDATA%/com.servermanager.desktop/env/prod-api.env
#   %APPDATA%/com.servermanager.desktop/env/staging.env
#
# Do NOT commit real secrets.

SSH_PASSWORD=change-me

# Or private key auth:
# SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----
# ...
# -----END OPENSSH PRIVATE KEY-----"
